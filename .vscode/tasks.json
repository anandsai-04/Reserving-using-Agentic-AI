{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: install dependencies",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}/backend/requirements-dev.txt"
      ],
      "problemMatcher": []
    },
    {
      "label": "Backend: run tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "pytest",
        "backend"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Frontend: dev server",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    }
  ]
}
